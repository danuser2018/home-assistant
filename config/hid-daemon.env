# Ruta absoluta al archivo YAML de bindings y configuración
HID_CONFIG_PATH=/home/danuser2018/workspace/home-assistant/config/hid-daemon.yaml

# Ruta del dispositivo HID a escuchar (opcional, ej. /dev/input/event0)
# HID_DEVICE_PATH=

# Nombre del dispositivo HID a escuchar (opcional, ej. "USB Foot Switch")
# HID_DEVICE_NAME=

# Tiempo de reintento de conexión (opcional, en segundos)
# HID_RECONNECT_DELAY_S=
