# =============================================================================
# Configuración de speaker-watchdog
# =============================================================================
# IMPORTANTE: Ajusta WATCHDOG_DIR con la ruta absoluta a la carpeta
# data/output/ de este proyecto antes de instalar el servicio.
# =============================================================================

# Directorio que speaker-watchdog monitorizará en busca de archivos .wav.
# Debe apuntar a la carpeta data/output/ del proyecto home-assistant.
# Ejemplo: /home/TU_USUARIO/home-assistant/data/output
WATCHDOG_DIR=/home/danuser2018/workspace/home-assistant/data/output

# Nivel de logging del servicio.
# Opciones: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
