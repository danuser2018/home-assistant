# =============================================================================
# Configuración de mic-daemon
# =============================================================================
# IMPORTANTE: Ajusta MIC_OUTPUT_DIR con la ruta absoluta a la carpeta
# data/input/ de este proyecto antes de instalar el servicio.
# =============================================================================

# Directorio donde se guardarán los archivos .wav grabados.
# Debe apuntar a la carpeta data/input/ del proyecto home-assistant.
# Ejemplo: /home/TU_USUARIO/home-assistant/data/input
MIC_OUTPUT_DIR=/home/danuser2018/workspace/home-assistant/data/input

# (Opcional) Dispositivo de audio a utilizar.
# Dejar vacío para usar el dispositivo predeterminado del sistema.
# Para ver los dispositivos disponibles:
#   python3 -c "import sounddevice as sd; print(sd.query_devices())"
MIC_DEVICE=

# Sample rate en Hz. Debe ser 16000 para compatibilidad con el servicio STT.
MIC_SAMPLE_RATE=16000

# Número de canales de audio (1 = mono, recomendado).
MIC_CHANNELS=1

# (Opcional) URL del servidor NATS broker para recibir comandos de captura de habla.
NATS_URL=nats://localhost:4222
