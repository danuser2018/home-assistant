# =============================================================================
# Orchestrator Configuration (orchestrator)
# =============================================================================

# Level of logging detail
LOG_LEVEL=INFO

# Umbral mínimo de similitud para selección de plugins
SIMILARITY_THRESHOLD=60.0

# Umbral de desempate/ambigüedad por prioridad
TIE_BREAKER_THRESHOLD=5.0

# Pesos de algoritmos de similitud (deben sumar exactamente 1.0)
WEIGHT_RATIO=0.20
WEIGHT_PARTIAL_RATIO=0.30
WEIGHT_TOKEN_SORT_RATIO=0.20
WEIGHT_TOKEN_SET_RATIO=0.30

