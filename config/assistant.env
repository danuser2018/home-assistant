# =============================================================================
# Configuración de los servicios Docker del asistente de voz
# =============================================================================
# Este archivo es cargado por los contenedores stt, orchestrator, tts, mail-watchdog e identity-service.
# Las variables no reconocidas por cada servicio son ignoradas.
#
# Copia este archivo a config/assistant.env y ajusta los valores si es necesario.
# =============================================================================

# ---------------------------------------------------------------------------
# STT Capability (stt-capability)
# ---------------------------------------------------------------------------
# Modelo de Whisper a utilizar.
# Opciones: tiny (~400 MB), base (~750 MB), small (~1.5 GB), medium (~3 GB)
# Recomendado para uso general: base
WHISPER_MODEL=base

# Dispositivo de inferencia: cpu o cuda (si dispones de GPU NVIDIA)
WHISPER_DEVICE=cpu

# ---------------------------------------------------------------------------
# TTS Capability (tts-capability)
# ---------------------------------------------------------------------------
# Identificador base del modelo de voz de Piper TTS.
TTS_MODEL_NAME=es_ES-carlfm-x_low

# Directorio donde residen los modelos locales de Piper dentro del contenedor.
TTS_MODEL_DIR=/app/models

# URL del modelo de voz de Piper TTS (.onnx) para la descarga automática durante la instalación.
# Su correspondiente archivo de configuración se descargará añadiendo ".json" al final de la URL.
TTS_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/es/es_ES/carlfm/x_low/es_ES-carlfm-x_low.onnx

# ---------------------------------------------------------------------------
# Shared (todos los servicios Docker)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# System Service (system-service)
# ---------------------------------------------------------------------------
# Información de identidad del asistente Nova.
NOVA_NAME=Nova
NOVA_AUTHOR=Xeretre studios
NOVA_VERSION=2.0.0
NOVA_DESCRIPTION=Asistente personal de voz y automatización

# ---------------------------------------------------------------------------
# Mail Watchdog (mail-watchdog)
# ---------------------------------------------------------------------------
# Configuración SMTP para el servicio de envío de correos.
# Ajusta estos valores con los datos de tu servidor SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_user@gmail.com
SMTP_PASSWORD=your_password
SMTP_FROM="Nova <your_user@gmail.com>"

# Configuración de reintentos y sondeo
MAIL_POLL_INTERVAL=2
MAIL_MAX_RETRIES=3
MAIL_BACKOFF_BASE=2

# ---------------------------------------------------------------------------
# Orchestrator (orchestrator)
# ---------------------------------------------------------------------------
# Directorio donde se escriben los correos pendientes para que los procese mail-watchdog
MAIL_PENDING_DIR=/shared/mail/pending

# ---------------------------------------------------------------------------
# Identity Service (identity-service)
# ---------------------------------------------------------------------------
# Nombre real del usuario registrado en el sistema
USER_NAME=David

# Dirección de correo electrónico lógica del usuario
USER_EMAIL=david@example.com



