# =============================================================================
# Configuración de los servicios Docker del asistente de voz
# =============================================================================
# Este archivo es cargado por los contenedores stt, orchestrator y tts.
# Las variables no reconocidas por cada servicio son ignoradas.
#
# Copia este archivo a config/assistant.env y ajusta los valores si es necesario.
# =============================================================================

# ---------------------------------------------------------------------------
# STT Capability (stt-capability)
# ---------------------------------------------------------------------------
# Modelo de Whisper a utilizar.
# Opciones: tiny (~400 MB), base (~750 MB), small (~1.5 GB), medium (~3 GB)
# Recomendado para uso general: base
WHISPER_MODEL=base

# Dispositivo de inferencia: cpu o cuda (si dispones de GPU NVIDIA)
WHISPER_DEVICE=cpu

# ---------------------------------------------------------------------------
# Shared (todos los servicios Docker)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# System Service (system-service)
# ---------------------------------------------------------------------------
# Información de identidad del asistente Nova.
NOVA_NAME=Nova
NOVA_AUTHOR=Xeretre studios
NOVA_VERSION=2.0.0
NOVA_DESCRIPTION=Asistente personal de voz y automatización
