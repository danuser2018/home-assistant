# =============================================================================
# Plantilla de variables de entorno - Home Assistant
# =============================================================================
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env
# =============================================================================

# Ruta absoluta a la carpeta data/ de este proyecto.
# Es compartida entre los servicios del host y los contenedores Docker.
# Ejemplo: /home/TU_USUARIO/home-assistant/data
HOME_ASSISTANT_DATA_DIR=
